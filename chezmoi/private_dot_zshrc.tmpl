# ZSH config
export ZSH=$HOME/.oh-my-zsh
export ZSH_COMPDUMP=$ZSH/cache/.zcompdump-$HOST

# Set editor
# export VISUAL="mate -w"
# export EDITOR="mate -w"

# Set custom theme
export ZSH_THEME="tijs"

# Load plugins
plugins=(
  git 
  jsontools 
  npm
)

# Source other files
source $ZSH/oh-my-zsh.sh
source $HOME/dotfiles/zsh/.zsh_aliases
source $HOME/dotfiles/zsh/.zsh_functions

# Set language environment
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8

# Load custom commands
export PATH="$HOME/dotfiles/bin:$PATH"
export PATH="$HOME/.composer/vendor/bin:$PATH"

# GitHub token for homebrew
export HOMEBREW_GITHUB_API_TOKEN="{{ onepasswordRead "op://Private/github.com/HOMEBREW_GITHUB_API_TOKEN" }}"

# Sentry token
export SENTRY_TOKEN="{{ onepasswordRead "op://Private/bkehhkolzwjudvxawcdw65ax24/SENTRY_TOKEN" }}"

# Volta
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# rbenv
eval "$(rbenv init - zsh)"

# Symfony CLI autocomplation
eval "$(symfony self:completion zsh)"

# Brew
export HOMEBREW_NO_ENV_HINTS=1

# Sumo Gitlab
export SUMO_GITLAB_ACCESS_TOKEN="{{ onepasswordRead "op://Private/rdnhoairyhqgfwy5x7yk4fp3me/SUMO_GITLAB_ACCESS_TOKEN" }}"

# Pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - zsh)"
export PATH=/Users/tijs/.meteor:$PATH

